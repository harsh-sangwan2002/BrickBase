PORT=4000
NODE_ENV=development

# Supabase project settings (Project Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=BrickBase <no-reply@brickbase.app>

# No config needed for property location / nearby amenities — powered by
# OpenStreetMap (Nominatim + Overpass API), no API key required.

# Meilisearch (typo-tolerant, faceted search) — optional. Run `docker compose up -d`
# from the repo root to start it locally. Leave blank to fall back to Postgres full-text
# search (still works, just not typo-tolerant).
MEILISEARCH_HOST=http://localhost:7700
MEILI_MASTER_KEY=brickbase-dev-master-key

# Groq (free-tier LLM inference, groq.com) — powers the AI chatbot widget. Leave blank to
# disable the widget's replies. Get a free key at https://console.groq.com/keys.
GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
